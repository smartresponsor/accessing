<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}{{ accessing_product_name }}{% endblock %}</title>
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css">
    </head>
    <body class="bg-body-tertiary">
        <nav class="navbar navbar-expand-lg bg-dark navbar-dark mb-4">
            <div class="container">
                <a class="navbar-brand" href="{{ path('accessing_home') }}">{{ accessing_product_name }}</a>
                <div class="navbar-nav ms-auto gap-2">
                    <a class="nav-link" href="{{ path('accessing_home') }}">Home</a>
                    <a class="nav-link" href="{{ path('accessing_login') }}">Sign in</a>
                    <a class="nav-link" href="{{ path('accessing_overview') }}">Overview</a>
                </div>
            </div>
        </nav>

        <main class="container pb-5">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label }}">{{ message }}</div>
                {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}
        </main>
    </body>
</html>

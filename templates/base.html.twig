<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}{{ accessing_product_name }}{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-body-tertiary">
<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
        <a class="navbar-brand fw-semibold" href="{{ path(app.user ? 'accessing_overview' : 'accessing_sign_in') }}">{{ accessing_product_name }}</a>
        <div class="collapse navbar-collapse show">
            <ul class="navbar-nav me-auto">
                {% if app.user %}
                    <li class="nav-item"><a class="nav-link" href="{{ path('accessing_overview') }}">Overview</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('accessing_verify_email') }}">Verification</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('accessing_second_factor') }}">Second Factor</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('accessing_sessions') }}">Sessions</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('accessing_security_events') }}">Security Events</a></li>
                    {% if is_granted('ROLE_SUPPORT') %}
                        <li class="nav-item"><a class="nav-link" href="{{ path('accessing_operator_accounts') }}">Operator</a></li>
                    {% endif %}
                {% endif %}
            </ul>
            <div class="d-flex gap-2">
                {% if app.user %}
                    <span class="navbar-text text-light">{{ app.user.displayName }}</span>
                    <form method="post" action="{{ path('accessing_sign_out') }}">
                        <button class="btn btn-outline-light btn-sm" type="submit">Sign out</button>
                    </form>
                {% else %}
                    <a class="btn btn-outline-light btn-sm" href="{{ path('accessing_sign_in') }}">Sign in</a>
                    <a class="btn btn-primary btn-sm" href="{{ path('accessing_register') }}">Register</a>
                {% endif %}
            </div>
        </div>
    </div>
</nav>

<main class="container py-4">
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'danger' ? 'danger' : label == 'secondary' ? 'secondary' : label }} shadow-sm">{{ message }}</div>
        {% endfor %}
    {% endfor %}

    {% block body %}{% endblock %}
</main>
</body>
</html>

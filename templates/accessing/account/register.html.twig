{% extends 'base.html.twig' %}

{% block title %}Register | {{ accessing_product_name }}{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h1 class="h3 mb-3">Register an account</h1>
                    <p class="text-body-secondary">Create an Accessing account and start the verification flow immediately.</p>
                    {{ form_start(form) }}
                        {{ form_row(form.displayName) }}
                        {{ form_row(form.emailAddress) }}
                        {{ form_row(form.plainPassword) }}
                        <button class="btn btn-primary">Register</button>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}{{ accessing_product_name }} · Sign up{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h1 class="h4 mb-3">Sign up</h1>
                    <p class="text-secondary">Create a new account to start the Accessing lifecycle.</p>

                    {{ form_start(form) }}
                        {{ form_row(form.email) }}
                        {{ form_row(form.plainPassword) }}
                        {{ form_row(form.displayName) }}
                        {{ form_row(form.phoneNumber) }}
                        {{ form_row(form.submit) }}
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}

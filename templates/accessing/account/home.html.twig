{% extends 'base.html.twig' %}

{% block title %}{{ accessing_product_name }} · Account access{% endblock %}

{% block body %}
    <div class="row g-4 align-items-stretch">
        <div class="col-lg-8">
            <div class="card shadow-sm h-100">
                <div class="card-body p-4">
                    <span class="badge text-bg-dark mb-3">Symfony 8 security brick</span>
                    <h1 class="h3 mb-3">Account access lifecycle starts here</h1>
                    <p class="text-secondary mb-4">
                        Accessing is the ecosystem account-access component for registration, sign-in, verification,
                        second factor, recovery, sessions, and security events.
                    </p>
                    <div class="d-flex flex-wrap gap-2">
                        <a class="btn btn-primary" href="{{ path('accessing_login') }}">Open sign in</a>
                        <a class="btn btn-outline-secondary" href="{{ path('accessing_overview') }}">Open overview</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card shadow-sm h-100">
                <div class="card-body p-4">
                    <h2 class="h5">Current focus</h2>
                    <ul class="mb-0 text-secondary">
                        <li>bootstrap the Symfony security stack</li>
                        <li>stabilize Account entity and storage</li>
                        <li>grow verification and recovery flows next</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    {% if account is not null %}
        <div class="alert alert-success mt-4 mb-0">
            Signed in as <strong>{{ account.userIdentifier }}</strong>.
        </div>
    {% endif %}
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}{{ accessing_product_name }} · Email verified{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card shadow-sm border-success">
                <div class="card-body p-4">
                    <span class="badge text-bg-success mb-3">Verification completed</span>
                    <h1 class="h4 mb-3">Email address verified</h1>
                    <p class="text-secondary mb-4">
                        The account <strong>{{ account.email }}</strong> has completed the current email verification challenge.
                    </p>
                    <div class="d-flex flex-wrap gap-2">
                        <a class="btn btn-primary" href="{{ path('accessing_sign_in') }}">Go to sign in</a>
                        <a class="btn btn-outline-secondary" href="{{ path('accessing_home') }}">Back to home</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

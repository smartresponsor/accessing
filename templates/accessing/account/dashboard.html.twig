{% extends 'base.html.twig' %}

{% block title %}{{ accessing_product_name }} · Dashboard{% endblock %}

{% block body %}
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h1 class="h4 mb-3">Dashboard</h1>

                    {% if account is null %}
                        <div class="alert alert-warning mb-0">
                            No authenticated account is available in the current request context.
                        </div>
                    {% else %}
                        <dl class="row mb-0">
                            <dt class="col-sm-4">Email</dt>
                            <dd class="col-sm-8">{{ account.email }}</dd>
                            <dt class="col-sm-4">Display name</dt>
                            <dd class="col-sm-8">{{ account.displayName ?: '—' }}</dd>
                            <dt class="col-sm-4">Email verified</dt>
                            <dd class="col-sm-8">{{ account.emailVerifiedAt ? account.emailVerifiedAt|date('Y-m-d H:i:s') : 'Pending' }}</dd>
                            <dt class="col-sm-4">Phone verified</dt>
                            <dd class="col-sm-8">{{ account.phoneVerifiedAt ? account.phoneVerifiedAt|date('Y-m-d H:i:s') : 'Pending' }}</dd>
                            <dt class="col-sm-4">Second factor</dt>
                            <dd class="col-sm-8">{{ account.secondFactorEnabled ? 'Enabled' : 'Disabled' }}</dd>
                            <dt class="col-sm-4">Locked</dt>
                            <dd class="col-sm-8">{{ account.locked ? 'Yes' : 'No' }}</dd>
                            <dt class="col-sm-4">Failed logins</dt>
                            <dd class="col-sm-8">{{ account.failedLoginCount }}</dd>
                        </dl>
                    {% endif %}
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h2 class="h5">Next product steps</h2>
                    <ul class="mb-0 text-secondary">
                        <li>registration DTO + form</li>
                        <li>email verification flow</li>
                        <li>TOTP enrollment and recovery</li>
                        <li>security event audit views</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

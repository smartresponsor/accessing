{% extends 'base.html.twig' %}

{% block title %}{{ accessing_product_name }} · Security events{% endblock %}

{% block body %}
    <div class="card shadow-sm">
        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h1 class="h4 mb-0">Security events</h1>
                <span class="badge text-bg-secondary">Latest 50</span>
            </div>

            {% if events is empty %}
                <div class="alert alert-secondary mb-0">No security events recorded yet.</div>
            {% else %}
                <div class="table-responsive">
                    <table class="table table-striped align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Occurred at</th>
                                <th>Type</th>
                                <th>IP</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for event in events %}
                                <tr>
                                    <td>{{ event.occurredAt|date('Y-m-d H:i:s') }}</td>
                                    <td><code>{{ event.eventType }}</code></td>
                                    <td>{{ event.ipAddress ?: '—' }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}
